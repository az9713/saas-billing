# ── Database ──────────────────────────────────────────────────────────────────
# Get a free PostgreSQL URL from https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@localhost:5432/saas_billing"

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
# Get a free Redis URL from https://upstash.com
REDIS_URL="redis://localhost:6379"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ── Stripe (add when building billing features) ───────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
